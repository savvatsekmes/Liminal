# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Build output
frontend/dist/
frontend/build/

# Electron-builder output (huge — packaged app + bundled node_modules)
build/
dist/
dist-installers/

# Database & data
# Glob (`*`) instead of trailing slash so we can selectively un-include
# product data subdirs like `quotes/` while still ignoring user runtime
# data (db, voices, embeddings cache, etc.). Trailing-slash form would
# block any un-include of children.
backend/data/*
!backend/data/*.js
!backend/data/quotes/
!backend/data/quotes/*.json
*.db
*.db-shm
*.db-wal

# Logs
*.log
backend.log
frontend.log
tts_server.log

# Environment
.env
.env.local
.env.*.local
backend/.env

# IDE / Claude Code
.claude/
.mcp.json
.vscode/

# OS
.DS_Store
Thumbs.db

# TTS Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/
.venv-tts/
.venv-turbo/

# Personal voice clones — local-only, never ship to the public build
backend/default-voices/For_Savva_Only/

# Personal data exports
notion_import_data.json
