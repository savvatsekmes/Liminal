{
  "name": "liminal",
  "version": "1.1.0",
  "description": "Liminal — personal AI journaling desktop app",
  "author": "Savva Tsekmes",
  "license": "UNLICENSED",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build:frontend": "cd frontend && npm run build",
    "build:tts": "pyinstaller tts_server.spec --noconfirm",
    "build": "npm run build:frontend && npm run build:tts",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:mac": "npm run build && electron-builder --mac dmg",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.savvatsekmes.liminal",
    "productName": "Liminal",
    "directories": {
      "output": "dist-installers",
      "buildResources": "electron/icons"
    },
    "files": [
      "electron/**/*",
      "!**/node_modules/**/{CHANGELOG.md,README.md,readme.md,test,tests,__tests__}",
      "!**/*.{md,map}"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!data/liminal.db",
          "!data/liminal.db-*",
          "!data/vectra/**",
          "!data/voices/**",
          "!data/avatars/**",
          "!data/models/**",
          "!**/.env",
          "!**/*.log"
        ]
      },
      {
        "from": "frontend/dist",
        "to": "frontend/dist"
      },
      {
        "from": "dist/tts_server",
        "to": "tts_server"
      }
    ],
    "win": {
      "target": ["zip"],
      "icon": "electron/icons/icon.ico",
      "artifactName": "Liminal-${version}-win-x64.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Liminal"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icons/icon.icns",
      "category": "public.app-category.lifestyle",
      "hardenedRuntime": true,
      "artifactName": "Liminal-${version}-${arch}.${ext}"
    },
    "dmg": {
      "title": "Liminal ${version}"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "electron/icons/icon.png",
      "category": "Utility",
      "artifactName": "Liminal-${version}.${ext}"
    }
  }
}
