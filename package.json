{
  "name": "liminal",
  "version": "1.3.1",
  "description": "Liminal — personal AI journaling desktop app",
  "author": "Savva Tsekmes",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dist": "electron-builder --prepackaged dist-installers/win-unpacked --win nsis-web",
    "rebuild:backend": "npx --yes @electron/rebuild --module-dir backend --types prod",
    "predist:mac": "npm run rebuild:backend",
    "dist:mac": "electron-builder --mac dmg --arm64"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.savvatsekmes.liminal",
    "productName": "Liminal",
    "copyright": "Copyright © 2026 Savva Tsekmes",
    "directories": {
      "output": "dist-installers",
      "buildResources": "electron"
    },
    "afterSign": "scripts/mac-adhoc-sign.js",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*", "!data/**", "data/*.js", "data/quotes/**", "!default-voices/For_Savva_Only/**", "!.env"]
      },
      {
        "from": "frontend/dist",
        "to": "frontend/dist"
      },
      {
        "from": "dist/tts_server",
        "to": "tts_server"
      }
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64"] }
      ],
      "icon": "electron/icons/icon.icns",
      "category": "public.app-category.lifestyle",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Liminal ${version}",
      "icon": "electron/icons/icon.icns"
    },
    "win": {
      "icon": "electron/icons/icon.ico",
      "target": [
        { "target": "nsis-web", "arch": ["x64"] }
      ],
      "publisherName": "Savva Tsekmes",
      "verifyUpdateCodeSignature": false
    },
    "nsisWeb": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "shortcutName": "Liminal",
      "uninstallDisplayName": "Liminal ${version}",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://pub-49a26f231ae84f14935d52da051f5c21.r2.dev"
      }
    ]
  }
}
